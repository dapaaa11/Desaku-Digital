datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  image     String?
  createdAt DateTime @default(now())
}

model ServiceRequest {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  image       String?
  whatsapp    String
}

model VillageProfile {
  id        Int      @id @default(autoincrement())
  name      String
  about     String
  vision    String
  mission   String
  address   String
  image     String?
  createdAt DateTime @default(now())
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String?
  image     String
  createdAt DateTime @default(now())
}

model Umkm {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  whatsapp    String
  address     String
  image       String?
  createdAt   DateTime @default(now())
}

model Surat {
  id        Int      @id @default(autoincrement())
  nama      String
  nik       String
  jenis     String
  keperluan String
  status    String   @default("DIPROSES")
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}
